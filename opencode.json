{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "engram": {
      "type": "local",
      "command": ["C:\\Users\\ismar\\bin\\engram-1.10.4.exe", "mcp"],
      "enabled": true
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=bfxkcmoccqgvkrrkkdju",
      "timeout": 20000,
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PAT}"
      },
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server"
      ],
      "enabled": true
    },
    "obsidian": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-obsidian",
        "C:\\Users\\ismar\\Documents\\obsidian\\ale"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp",
        "--headless",
        "--caps",
        "vision,devtools",
        "--isolated"
      ],
      "enabled": true
    }
  }
}

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase MCP Personal Access Token (PAT) - optional (CI/manual auth)
SUPABASE_ACCESS_TOKEN=

# Database Provider Selection
# supabase | local | postgres
DB_PROVIDER=supabase
# Client-side repository provider (transitional while migrating to full BFF)
NEXT_PUBLIC_DB_PROVIDER=supabase

# Venezuelan Payment Integration (Ubii, PagoFlash, Binance Pay)
# Ubii
NEXT_PUBLIC_UBII_LINK=https://link.ubii.com/pay/your-handle

# PagoFlash
PAGOFLASH_BASE_URL=https://pagoflash.com/payment-gateway-commerce
PAGOFLASH_BEARER_TOKEN=your-pagoflash-token

# Binance Pay
NEXT_PUBLIC_BINANCE_PAY_ID=your-binance-id

# Admin Configuration
ADMIN_USER_IDS=

# WebSocket Configuration (Optional)
NEXT_PUBLIC_WEBSOCKET_URL=

# AI Configuration
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google (Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
# AI Model Fallback Configuration (Google only)
# Comma-separated list: primary model first, then fallbacks
# If a model hits quota limit, automatically tries the next one
# Example: gemini-3-flash,gemini-2.5-flash,gemini-2.5-flash-lite
GOOGLE_MODEL_FALLBACK_CHAIN=

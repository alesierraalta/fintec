{
  "name": "fintec",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NODE_NO_WARNINGS=1 BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true BROWSERSLIST_IGNORE_OLD_DATA=true next build",
    "build:mobile": "npm run build && npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "start": "next start",
    "lint": "oxlint --quiet app components hooks lib repositories tests scripts",
    "lint:fix": "oxlint --fix app components hooks lib repositories tests scripts",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "cross-env BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true BROWSERSLIST_IGNORE_OLD_DATA=true jest",
    "test:ci": "cross-env BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true BROWSERSLIST_IGNORE_OLD_DATA=true jest --runInBand --detectOpenHandles",
    "test:watch": "cross-env BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true BROWSERSLIST_IGNORE_OLD_DATA=true jest --watch",
    "test:coverage": "cross-env BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true BROWSERSLIST_IGNORE_OLD_DATA=true jest --coverage",
    "test:load": "k6 run k6/api-stress-test.js",
    "test:mutate": "stryker run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:no-auth": "cross-env PLAYWRIGHT_NO_AUTH_SETUP=1 playwright test",
    "clean": "node scripts/clean.mjs build deps-cache ts",
    "clean:temp": "node scripts/clean.mjs temp",
    "clean:docs": "node scripts/clean.mjs docs",
    "clean:all": "npm run clean:temp && npm run clean:docs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "guard:db-access": "node scripts/guardrails/check-direct-db-access.mjs",
    "prepare": "husky",
    "precommit:staged": "lint-staged",
    "spellcheck": "cspell --config cspell.config.cjs --no-progress --no-summary \"{hooks,lib,repositories,tests}/**/*.{ts,tsx,js,jsx}\" || true",
    "spellcheck:strict": "cspell --config cspell.config.cjs --no-progress --no-summary \"{hooks,lib,repositories,tests}/**/*.{ts,tsx,js,jsx}\"",
    "secretlint": "secretlint \"{app,components,hooks,lib,repositories,tests,docs}/**/*\" --secretlintignore .secretlintignore",
    "prepush:verify": "npm run type-check && npm run lint && npm run test:ci && npm run build"
  },
  "overrides": {
    "next-auth": {
      "next": "$next"
    },
    "@stryker-mutator/core": {
      "ajv": "8.18.0"
    },
    "eslint": {
      "ajv": "8.18.0"
    },
    "@eslint/eslintrc": {
      "ajv": "8.18.0"
    }
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.5",
    "@ai-sdk/google": "^3.0.3",
    "@ai-sdk/openai": "^3.0.4",
    "@ai-sdk/react": "^3.0.9",
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@fontsource/inter": "^5.2.8",
    "@formkit/drag-and-drop": "^0.5.3",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.75.1",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.16",
    "@upstash/ratelimit": "^2.0.0",
    "@upstash/redis": "^1.34.0",
    "ai": "^6.0.9",
    "autoprefixer": "^10.4.19",
    "bcryptjs": "^3.0.2",
    "cheerio": "^1.1.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.18",
    "dexie": "^4.2.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.24",
    "hotkeys-js": "^3.13.15",
    "immer": "^10.1.3",
    "ioredis": "^5.3.2",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.546.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.12",
    "node-fetch": "^3.3.2",
    "postcss": "^8.4.39",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.65.0",
    "react-is": "19.2.0",
    "recharts": "^3.3.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@cspell/dict-es-es": "^3.0.8",
    "@playwright/test": "^1.56.1",
    "@secretlint/secretlint-rule-preset-recommend": "^11.2.4",
    "@stryker-mutator/core": "^9.4.0",
    "@stryker-mutator/jest-runner": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
    "@tailwindcss/forms": "^0.5.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cheerio": "^0.22.35",
    "@types/jest": "^30.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "baseline-browser-mapping": "^2.9.19",
    "cross-env": "^10.1.0",
    "cspell": "^8.19.4",
    "eslint": "^9.38.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "fast-check": "^4.4.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.5.2",
    "markdownlint-cli2": "^0.21.0",
    "oxlint": "^1.48.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "secretlint": "^11.2.4",
    "supabase": "^2.63.1",
    "tailwindcss": "^3.4.18",
    "ts-jest": "^29.4.6",
    "tsx": "^4.20.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

{
  "mcpServers": {
    "engram": {
      "command": "C:\\Users\\ismar\\bin\\engram.exe",
      "args": ["mcp"]
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server"
      ]
    },
    "supabase": {
      "httpUrl": "https://mcp.supabase.com/mcp"
    },
    "obsidian": {
      "command": "npx",
      "args": [
        "-y",
        "@mauricio.wolff/mcp-obsidian@latest",
        "C:\\Users\\ismar\\Documents\\obsidian\\ale"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp",
        "--headless",
        "--caps",
        "vision,devtools",
        "--isolated"
      ]
    }
  }
}
